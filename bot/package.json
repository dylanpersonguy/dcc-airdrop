    "nanoid": "^3.3.7",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
