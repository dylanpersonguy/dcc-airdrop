# ── Telegram ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
BOT_USERNAME=dcc_airdrop_bot

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dcc_airdrop_bot

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── DecentralChain RPC / Indexer ─────────────────
DCC_NODE_URL=https://nodes.decentralchain.io
DCC_CHAIN_ID=D

# ── Smart Contract Addresses ─────────────────────
ELIGIBILITY_TRACKER_ADDRESS=3D...trackerAddress
AIRDROP_CLAIM_ADDRESS=3D...claimAddress
STDCC_ASSET_ID=assetIdHere

# ── Admin ────────────────────────────────────────
# Comma-separated Telegram user IDs
ADMIN_TELEGRAM_IDS=123456789,987654321

# ── Airdrop Campaign Config ─────────────────────
BASE_AIRDROP_AMOUNT=1000
ALLOCATION_MODE=base_plus_referral

# ── Multi-Level Referral Program ─────────────────
# Max depth of upline traversal (1 = direct only, 3 = three tiers)
REFERRAL_MAX_DEPTH=3
# Bonus token amount per referred user at each tier
REFERRAL_TIER1_BONUS=50
REFERRAL_TIER2_BONUS=25
REFERRAL_TIER3_BONUS=10
# Max referral rewards credited per tier per user
MAX_REFERRAL_REWARDS_PER_TIER=50

# ── Claim ────────────────────────────────────────
CLAIM_LIVE=false

# ── Verification ─────────────────────────────────
CHALLENGE_EXPIRY_MINUTES=30
VERIFICATION_METHOD=transfer_memo

# ── Wallet Encryption ────────────────────────────
# Secret used to encrypt seed phrases at rest (min 16 chars)
WALLET_ENCRYPTION_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars

# ── Rewards Wallet ───────────────────────────────
# Seed phrase of the wallet used to send instant invite rewards (1 DCC per invite)
REWARDS_WALLET_SEED=your twelve or fifteen word seed phrase here

# ── Bridge API ───────────────────────────────────
# SOL-Gateway-DCC bridge endpoint for buy flow
BRIDGE_API_URL=http://localhost:3000/api/v1

# ── NOWPayments API ──────────────────────────────
# API key from https://nowpayments.io (powers /buy crypto payments)
NOWPAYMENTS_API_KEY=your-nowpayments-api-key

# ── Rate Limits ──────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# ── Logging ──────────────────────────────────────
LOG_LEVEL=info

# ── Blockchain defaults ──────────────────────────
# Average block time in seconds (used for LP age calculations)
BLOCK_TIME_SECONDS=60
# Minimum LP age in blocks (~7 days at 1 block/min = 10080)
MIN_LP_AGE_BLOCKS=10080
MIN_STDCC_BALANCE=10000000000
